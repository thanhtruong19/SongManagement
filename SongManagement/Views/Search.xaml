<Window x:Class="SongManagement.Views.Search"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Search Songs" Height="400" Width="500">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Search Songs" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
            <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                <TextBlock Text="ID:"/>
                <TextBox Text="{Binding SearchID}" Margin="0,5"/>
                <TextBlock Text="Song Name:"/>
                <TextBox Text="{Binding SearchSongName}" Margin="0,5"/>
                <TextBlock Text="Singer Name:"/>
                <TextBox Text="{Binding SearchSingerName}" Margin="0,5"/>
                <TextBlock Text="Genre:"/>
                <TextBox Text="{Binding SearchGenre}" Margin="0,5"/>
                <TextBlock Text="Country:"/>
                <TextBox Text="{Binding SearchCountry}" Margin="0,5"/>
                <TextBlock Text="Release Date:"/>
                <TextBox Text="{Binding SearchReleaseDate}" Margin="0,5"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Back" Width="80" Margin="5" />
            <Button Content="Search" Width="80" Margin="5" Command="{Binding SearchCommand}"/>
        </StackPanel>
    </Grid>
</Window>
